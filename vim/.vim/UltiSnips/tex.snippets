global !p
def math():
	return vim.eval('vimtex#syntax#in_mathzone()') == '1'

def comment(): 
	return vim.eval('vimtex#syntax#in_comment()') == '1'

def env(name):
	[x,y] = vim.eval("vimtex#env#is_inside('" + name + "')") 
	return x != '0' and y != '0'

def create_matrix_placeholder(rows, cols, type_):
	"""Crée une matrice LaTeX avec tabstops UltiSnips"""
	# Compteur pour les tabstops
	tabstop = 1
	lines = []
	
	for row in range(rows):
		cols_list = []
		for col in range(cols):
			# Utilise ${{i}} pour que le $ externe soit un tabstop UltiSnips
			cols_list.append("${{{}}}".format(tabstop))
			tabstop += 1
		lines.append(" & ".join(cols_list))
	
	# Joint les lignes
	body = " \\\\\\\\\n\t".join(lines)
	
	result = "\\\\begin{{{}matrix}}\n\t{}\n\\\\end{{{}matrix}}".format(type_, body, type_)
	return result

endglobal


