endsnippet

priority 100
context "math()"
snippet '(?<!\\)(BB|CC|DD|FF|HH|II|JJ|KK|LL|NN|OO|PP|QQ|RR|SS|TT|VV|WW|XX|YY|ZZ)' "mathcal" rwA
\\`!p snip.rv = match.group(1)[0]`
endsnippet

priority 100
context "math()"
snippet MM "matrice" iA
\M_{${1:m} \times ${2:n}}(${3:K})$0
endsnippet

priority 200
context "math()"
snippet '(?<!\\)(aA|bB|cC|dD|eE|fF|gG|hH|iI|jJ|kK|lL|mM|nN|oO|pP|qQ|rR|sS|tT|uU|vV|wW|xX|yY|zZ)' "mathcal" rwA
\\`!p snip.rv = match.group(1)`
endsnippet

priority 100
context "math()"
snippet croi "croissante in math" iA
\nearrow 
endsnippet

priority 200
context "math()"
snippet dcroi "decroissante in math" iA
\searrow 
endsnippet

context "math()"
snippet dd "d" iA
\d
endsnippet

context "math()"
snippet pp "p" iA
\p
endsnippet


#context "math()"
#snippet "(\s)([A-Za-z])\(" "Wrap single letter in parentheses" rA
#`!p snip.rv = match.group(1) + match.group(2)`(${1:x})$0
#endsnippet
#
#context "math()"
#snippet "(\s)\\(alpha|beta|gamma|delta|epsilon|zeta|eta|theta|iota|kappa|lambda|mu|nu|xi|omicron|pi|rho|sigma|tau|upsilon|phi|chi|psi|omega|Alpha|Beta|Gamma|Delta|Epsilon|Zeta|Eta|Theta|Iota|Kappa|Lambda|Mu|Nu|Xi|Omicron|Pi|Rho|Sigma|Tau|Upsilon|Phi|Chi|Psi|Omega|cos|sin|tan|log)" "Wrap Greek letter in parentheses" r
#`!p snip.rv = match.group(1) + '\\' + match.group(2)`(${1:x})$0
#endsnippet

priority 1000
context "math()"
snippet de "add parentheses with arg" iA
(${1:x})$0
endsnippet

context "math()"
snippet "(\s|\(|\{|\|)([A-Za-z])([A-Za-z])([A-Za-z])" "put triplet in index" wr
`!p snip.rv = match.group(1) + match.group(2)`_{`!p snip.rv = match.group(3) + match.group(4)`}$0
endsnippet

context "math()"
snippet rep "repeat" iA
${1:v}_{${2:1}} ${3:,} \ldots $3 $1_{${4:n}}$0
endsnippet

priority 1000
snippet "(\s)([0-9]+)([0-9]+)b" "Matrix bmatrix NxM" r
`!p 
row = match.group(1)
snip.rv = row`
endsnippet

snippet "(\d+)b(\d+)" "Create bmatrix" r
`!p
rows = int(match.group(1))
cols = int(match.group(2))
snip.rv = create_matrix_placeholder(rows, cols, 'b')`$0
endsnippet

context "math()"
snippet com "commentaire" A
\underbrace{$1}_{\substack{$2}} $0
endsnippet

context "math()"
snippet scal "scalar product" iA
\l< $1 \r>$0
endsnippet

context "math()"
snippet \Rn "R n" iA
\R^{n}
endsnippet

context "math()"
snippet \Rm "R m" iA
\R^{m}
endsnippet

context "math()"
snippet abs "absolute value" iA
\l| $1 \r|$0
endsnippet

context "math()"
snippet iint "interieur" iA
\inte
endsnippet

# vim:ft=snippets

